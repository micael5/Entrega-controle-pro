    android:shape="rectangle">
    <solid android:color="#0F172A" /> <!-- slate 900 -->
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#1E293B" /> <!-- slate 800 border line -->
</shape>
